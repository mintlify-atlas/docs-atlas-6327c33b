  "keyFeatures": [
    "User authentication and authorization with password hashing",
    "Complete vehicle catalog management with search and filtering",
    "Rental booking system with availability checking",
    "User favorites for saving preferred vehicles",
    "Vehicle image management and storage",
    "Multi-criteria vehicle search (brand, model, year, type)",
    "Special offers and promotional pricing"
  ],
  "publicApiSurface": [
    "POST /api/auth/login - User authentication",
    "POST /api/auth/register - User registration",
    "GET /api/vehicles - List all vehicles with optional filtering",
    "GET /api/vehicles/{id} - Get vehicle details",
    "POST /api/vehicles - Create new vehicle",
    "PUT /api/vehicles/{id} - Update vehicle",
    "DELETE /api/vehicles/{id} - Delete vehicle",
    "GET /api/vehicles/search - Search vehicles by brand or model",
    "GET /api/vehicles/filter - Filter vehicles by multiple criteria",
    "GET /api/vehicles/brands - Get available vehicle brands",
    "POST /api/rentals - Create rental booking",
    "GET /api/rentals/{id} - Get rental details",
    "GET /api/rentals - List rentals by user or vehicle",
    "POST /api/rentals/{id}/cancel - Cancel rental",
    "POST /api/rentals/{id}/complete - Complete rental",
    "GET /api/rentals/availability - Check vehicle availability",
    "GET /api/users - List all users",
    "GET /api/users/{id} - Get user details",
    "POST /api/users - Create user",
    "PUT /api/users/{id} - Update user",
    "DELETE /api/users/{id} - Delete user",
    "GET /api/favourites/{userId} - Get user's favorite vehicles",
    "POST /api/favourites/{userId}/{vehicleId} - Add vehicle to favorites",
    "DELETE /api/favourites/{userId}/{vehicleId} - Remove vehicle from favorites"
  ]
}
